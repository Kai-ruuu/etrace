// ── Seeders ───────────────────────────────────────────────────────────────────

function runSeeder(?string $name, bool $prod): void
{
    if (!$name) {
        error("Seeder name is required. Usage: php wingman -rsd <SeederName>");
        exit(1);
    }

    $name = ucfirst($name);

    if (str_ends_with($name, 'Seeder')) {
        $name = substr($name, 0, -strlen('Seeder'));
    }

    $className = "App\\Seeders\\{$name}Seeder";
    $filePath  = SEEDERS_DIR . "/{$name}Seeder.php";

    if (!file_exists($filePath)) {
        error("Seeder not found at: {$filePath}");
        exit(1);
    }

    if (!class_exists($className)) {
        error("Seeder class '{$className}' not found. Did you run composer dump-autoload?");
        exit(1);
    }

    $env = $prod ? 'production' : 'development';
    info("Running \033[33m{$name}Seeder\033[0m on {$env}...");

    if ($prod) {
        echo "\033[31mAre you sure you want to seed PRODUCTION? (yes/no): \033[0m";
        $confirm = trim(fgets(STDIN));
        if ($confirm !== 'yes') {
            warn("Aborted.");
            exit(0);
        }
    }

    try {
        $pdo    = resolveDatabase($prod)->connect();
        $seeder = new $className();
        $seeder->seed($pdo);
        info("{$name}Seeder completed successfully.");
    } catch (\Exception $e) {
        error("Seeder failed: " . $e->getMessage());
        exit(1);
    }
}

function runAllSeeders(bool $prod): void
{
    if (!is_dir(SEEDERS_DIR)) {
        error("Seeders directory not found at: " . SEEDERS_DIR);
        exit(1);
    }

    $files = glob(SEEDERS_DIR . '/*Seeder.php');

    if (empty($files)) {
        warn("No seeders found in: " . SEEDERS_DIR);
        exit(0);
    }

    $env = $prod ? 'production' : 'development';
    info("Running \033[33mall seeders\033[0m on {$env}...");

    if ($prod) {
        echo "\033[31mAre you sure you want to seed PRODUCTION? (yes/no): \033[0m";
        $confirm = trim(fgets(STDIN));
        if ($confirm !== 'yes') {
            warn("Aborted.");
            exit(0);
        }
    }

    try {
        $pdo = resolveDatabase($prod)->connect();
    } catch (\Exception $e) {
        error("Database connection failed: " . $e->getMessage());
        exit(1);
    }

    usort($files, function ($a, $b) {
        $classA = "App\\Seeders\\" . basename($a, '.php');
        $classB = "App\\Seeders\\" . basename($b, '.php');
        $orderA = property_exists($classA, 'order') ? $classA::$order : 99;
        $orderB = property_exists($classB, 'order') ? $classB::$order : 99;
        return $orderA <=> $orderB;
    });

    foreach ($files as $file) {
        $name      = basename($file, '.php');
        $className = "App\\Seeders\\{$name}";

        if (!class_exists($className)) {
            warn("Skipping {$name} — class not found. Did you run composer dump-autoload?");
            continue;
        }

        try {
            $seeder = new $className();
            $seeder->seed($pdo);
            info("{$name} \033[32m\033[0m");
        } catch (\Exception $e) {
            error("{$name} \033[31m\033[0m — " . $e->getMessage());
        }
    }

    echo PHP_EOL;
}

// ── Migration ─────────────────────────────────────────────────────────────────

function resolveDatabase(bool $prod): \App\Core\Database
{
    if ($prod) {
        $dotenv = ROOT . '/.env';
        if (file_exists($dotenv)) {
            foreach (file($dotenv, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
                if (str_starts_with(trim($line), '#')) continue;
                [$key, $val] = array_map('trim', explode('=', $line, 2));
                $_ENV[$key]  = $val;
            }
        }
        return \App\Core\Database::forProd();
    }

    return \App\Core\Database::forDev();
}

function createTables(bool $prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running create tables on \033[33m{$env}\033[0m...");

    if ($prod) {
        echo "\033[31mAre you sure you want to run migrations on PRODUCTION? (yes/no): \033[0m";
        $confirm = trim(fgets(STDIN));
        if ($confirm !== 'yes') {
            warn("Aborted.");
            exit(0);
        }
    }

    try {
        $pdo      = resolveDatabase($prod)->connect();
        $migrator = new \App\Core\Migrator($pdo);
        $migrator->createTables();
        info("All tables created successfully.");
    } catch (\Exception $e) {
        error("Migration failed: " . $e->getMessage());
        exit(1);
    }
}

function dropTables(bool $prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running drop tables on \033[33m{$env}\033[0m...");

    try {
        $pdo = resolveDatabase($prod)->connect();
        $pdo->exec("SET FOREIGN_KEY_CHECKS = 0");

        $migrator = new \App\Core\Migrator($pdo);
        $migrator->dropTables();

        $pdo->exec("SET FOREIGN_KEY_CHECKS = 1");
        info("All tables dropped successfully.");
    } catch (\Exception $e) {
        error("Drop failed: " . $e->getMessage());
        exit(1);
    }
}

function recreateTables(bool $prod): void
{
    dropTables($prod);
    echo PHP_EOL;
    createTables($prod);
}

// ── Server ────────────────────────────────────────────────────────────────────

function run(bool $prod): void
{
    $host = $prod ? "0.0.0.0" : "localhost";
    $port = 8000;

    info("Starting server at \033[33mhttp://{$host}:{$port}\033[0m...");
    exec("php -S {$host}:{$port} index.php");
}

function initializeUploads(bool $prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running \033[33muploads initialization \033[0m on {$env}...");

    $UploadManager = new UploadManager();

    try {
        $UploadManager->initialize();
    } catch (Exception $e) {
        $UploadManager->reset();
        error_log('Failed: Unable to initialize uploads folder - ' . $e->getMessage());
    }
}

function resetUploads(bool $prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running \033[33muploads reset \033[0m on {$env}...");
    
    $UploadManager = new UploadManager();
    $UploadManager->reset();

    initializeUploads($prod);
}

function initializeServer($prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running \033[33mserver initialization \033[0m on {$env}...");

    initializeUploads($prod);
    createTables($prod);
    runAllSeeders($prod);
}

function resetServer($prod): void
{
    $env = $prod ? 'production' : 'development';
    info("Running \033[33mserver reset \033[0m on {$env}...");

    resetUploads($prod);
    recreateTables($prod);
    runAllSeeders($prod);
}

// ── Fallback ──────────────────────────────────────────────────────────────────

function unrecognized(?string $flag): void
{
    error("Unrecognized flag: '{$flag}'");
    usage();
    exit(1);
}
