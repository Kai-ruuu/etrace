#!/usr/bin/env php
<?php

use App\Core\UploadManager;

require_once __DIR__ . "/vendor/autoload.php";

$dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
$dotenv->load();

// ── Config ────────────────────────────────────────────────────────────────────

define('ROOT',            dirname(__FILE__));
define('MODELS_DIR',      ROOT . '/App/Models');
define('CONTROLLERS_DIR', ROOT . '/App/Controllers');
define('SERVICES_DIR',    ROOT . '/App/Services');
define('SEEDERS_DIR',     ROOT . '/App/Seeders');
define('KIT_MODEL',       ROOT . '/Kit/Model.php');
define('KIT_CONTROLLER',  ROOT . '/Kit/Controller.php');
define('KIT_SERVICE',     ROOT . '/Kit/Service.php');
define('KIT_SEEDER',      ROOT . '/Kit/Seeder.php');
define('MIDDLEWARES_DIR', ROOT . '/App/Middlewares');
define('KIT_MIDDLEWARE',  ROOT . '/Kit/BaseMiddleware.php');

// Auto-load composer so Database, Migration, and models are available
$autoload = ROOT . '/vendor/autoload.php';
if (file_exists($autoload)) {
    require_once $autoload;
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function info(string $msg): void  { echo "\033[32m[wingman]\033[0m {$msg}" . PHP_EOL; }
function error(string $msg): void { echo "\033[31m[error]\033[0m {$msg}" . PHP_EOL; }
function warn(string $msg): void  { echo "\033[33m[warn]\033[0m {$msg}" . PHP_EOL; }

function usage(): void
{
    echo PHP_EOL;
    echo "\033[33mWingman\033[0m" . PHP_EOL;
    echo "────────────────────────────────────────────────────" . PHP_EOL;
    echo "  \033[36mGeneration\033[0m" . PHP_EOL;
    echo "    php wingman -nm  <ModelName>       Generate a new model" . PHP_EOL;
    echo "    php wingman -nc  <ControllerName>  Generate a new controller" . PHP_EOL;
    echo "    php wingman -nsv <ServiceName>     Generate a new service" . PHP_EOL;
    echo "    php wingman -nsd <SeederName>      Generate a new seeder" . PHP_EOL;
    echo "    php wingman -nmd <MiddlewareName>  Generate a new middleware" . PHP_EOL;
    echo PHP_EOL;
    echo "  \033[36mMigrations\033[0m" . PHP_EOL;
    echo "    php wingman -ct                    Create all tables (dev)" . PHP_EOL;
    echo "    php wingman -ct --prod             Create all tables (prod)" . PHP_EOL;
    echo "    php wingman -dt                    Drop all tables (dev)" . PHP_EOL;
    echo "    php wingman -dt --prod             Drop all tables (prod)" . PHP_EOL;
    echo "    php wingman -rt                    Recreate all tables (dev) (drop then create)" . PHP_EOL;
    echo "    php wingman -rt --prod             Recreate all tables (prod) (drop then create)" . PHP_EOL;
    echo PHP_EOL;
    echo "  \033[36mSeeders\033[0m" . PHP_EOL;
    echo "    php wingman -rsd <SeederName>      Run a specific seeder (dev)" . PHP_EOL;
    echo "    php wingman -rsd <SeederName> --prod  Run a specific seeder (prod)" . PHP_EOL;
    echo "    php wingman -rasd                   Run all seeders (dev)" . PHP_EOL;
    echo "    php wingman -rasd --prod            Run all seeders (prod)" . PHP_EOL;
    echo PHP_EOL;
    echo "  \033[36mServer\033[0m" . PHP_EOL;
    echo "    php wingman -r                     Run (dev)" . PHP_EOL;
    echo "    php wingman -r  --prod             Run (prod)" . PHP_EOL;
    echo "    php wingman -iu                    Initialize uploads (dev)" . PHP_EOL;
    echo "    php wingman -iu --prod             Initialize uploads (prod)" . PHP_EOL;
    echo "    php wingman -ru                    Reset uploads (dev)" . PHP_EOL;
    echo "    php wingman -ru --prod             Reset uploads (prod)" . PHP_EOL;
    echo "    php wingman -is                    Initialize server (dev)" . PHP_EOL;
    echo "    php wingman -is --prod             Initialize server (prod)" . PHP_EOL;
    echo "    php wingman -rs                    Reset server (dev)" . PHP_EOL;
    echo "    php wingman -rs --prod             Reset server (prod)" . PHP_EOL;
    echo PHP_EOL;
}

// ── Arg Parsing ───────────────────────────────────────────────────────────────

$args = array_slice($argv, 1);

if (empty($args)) {
    usage();
    exit(1);
}

$flag = $args[0] ?? null;
$name = $args[1] ?? null;
$prod = in_array('--prod', $args);

// ── Commands ──────────────────────────────────────────────────────────────────

match($flag) {
    '-nm'   => generateModel($name),
    '-nc'   => generateController($name),
    '-nsv'  => generateService($name),
    '-nsd'  => generateSeeder($name),
    '-ct'   => createTables($prod),
    '-dt'   => dropTables($prod),
    '-rt'   => recreateTables($prod),
    '-rsd'  => runSeeder($name, $prod),
    '-rasd' => runAllSeeders($prod),
    '-r'    => run($prod),
    '-iu'   => initializeUploads($prod),
    '-ru'   => resetUploads($prod),
    '-is'   => initializeServer($prod),
    '-rs'   => resetServer($prod),
    '-nmd'  => generateMiddleware($name),
    default => unrecognized($flag),
};

// ── Generators ────────────────────────────────────────────────────────────────

function generateModel(?string $name): void
{
    if (!$name) {
        error("Model name is required. Usage: php wingman -nm <ModelName>");
        exit(1);
    }

    $name = ucfirst($name);

    if (!preg_match('/^[A-Za-z]+$/', $name)) {
        error("Model name must contain letters only. Got: '{$name}'");
        exit(1);
    }

    $kitPath    = KIT_MODEL;
    $outputPath = MODELS_DIR . "/{$name}.php";
    $tableName  = strtolower(preg_replace('/(?<!^)[A-Z]/', '_$0', $name)) . 's';

    if (!file_exists($kitPath)) {
        error("Kit template not found at: {$kitPath}");
        exit(1);
    }

    if (file_exists($outputPath)) {
        warn("Model already exists at: {$outputPath}");
        exit(1);
    }

    if (!is_dir(MODELS_DIR)) {
        mkdir(MODELS_DIR, 0755, true);
        info("Created directory: " . MODELS_DIR);
    }

    $template = file_get_contents($kitPath);

    $content = str_replace(
        ['class Model', 'function fromRow', 'table_name'],
        ["class {$name}", 'function fromRow', $tableName],
        $template
    );

    if (file_put_contents($outputPath, $content) === false) {
        error("Failed to write file at: {$outputPath}");
        exit(1);
    }

    info("Model created      : App/Models/{$name}.php");
    info("Table name         : {$tableName}");
}

